# ----- Publish -----
# Sættes som GitHub Actions secret (NPM_TOKEN). Lokalt kan du sætte den i ~/.npmrc.
NPM_TOKEN=

# ----- Bimo-Nexus runtime (bruges af @bimo-dk/nexus-cli til publish, status, health) -----
BIMO_TOKEN=change-this-to-a-strong-secret-in-production
REGISTRY_URL=http://localhost:3000

# ----- CLI defaults -----
REMOTE_URL=
