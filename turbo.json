{
  "$schema": "https://turborepo.com/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".angular-cache/**"],
      "inputs": [
        "src/**",
        "package.json",
        "tsconfig*.json",
        "ng-package.json",
        "tsup.config.ts"
      ]
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": ["coverage/**"],
      "inputs": [
        "src/**",
        "test/**",
        "package.json",
        "tsconfig*.json"
      ]
    },
    "lint": {
      "outputs": [],
      "inputs": ["src/**", ".eslintrc*", "eslint.config.*"]
    },
    "type-check": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "clean": {
      "cache": false,
      "outputs": []
    },
    "@bimo-dk/nexus-runtime-core#build": {
      "dependsOn": ["@bimo-dk/nexus-core#build", "@bimo-dk/nexus-client#build"]
    },
    "@bimo-dk/nexus-runtime#build": {
      "dependsOn": ["@bimo-dk/nexus-runtime-core#build"]
    },
    "@bimo-dk/nexus-runtime-vue#build": {
      "dependsOn": ["@bimo-dk/nexus-runtime-core#build"]
    },
    "@bimo-dk/nexus-runtime-react#build": {
      "dependsOn": ["@bimo-dk/nexus-runtime-core#build"]
    }
  }
}
