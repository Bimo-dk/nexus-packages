{
  "name": "@bimo-dk/nexus-runtime-react",
  "version": "0.1.0",
  "description": "React 18 provider, hooks, and NexusComponent for Bimo-Nexus hosts and remotes",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bimo-dk/nexus-packages.git",
    "directory": "packages/runtime-react"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "echo \"(skipping lint — no eslint config yet)\" && exit 0",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@bimo-dk/nexus-core": "*",
    "@bimo-dk/nexus-client": "*",
    "@bimo-dk/nexus-runtime-core": "*"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "react-dom": "^18.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
