{
  "name": "@bimo-dk/nexus-testing",
  "version": "0.1.0",
  "description": "Test utilities, mock factories og in-memory MockRegistryServer for Bimo-Nexus",
  "license": "AGPL-3.0-or-later",
  "author": "Steffen Vitten Pedersen <svp@bimo.dk>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bimo-dk/nexus-packages.git",
    "directory": "packages/testing"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./angular": {
      "types": "./dist/angular.d.ts",
      "import": "./dist/angular.mjs",
      "require": "./dist/angular.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "lint": "echo \"(skipping lint — no eslint config yet)\" && exit 0",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@bimo-dk/nexus-core": "*",
    "@bimo-dk/nexus-client": "*",
    "express": "^5.0.1",
    "ws": "^8.18.0"
  },
  "peerDependencies": {
    "@angular/core": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@angular/core": { "optional": true }
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
