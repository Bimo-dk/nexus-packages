{
  "name": "@bimo-dk/nexus-runtime-vue",
  "version": "0.1.0",
  "description": "Vue 3 plugin, composables, and NexusComponent for Bimo-Nexus hosts and remotes",
  "license": "AGPL-3.0-or-later",
  "author": "Steffen Vitten Pedersen <svp@bimo.dk>",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bimo-dk/nexus-packages.git",
    "directory": "packages/runtime-vue"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "echo \"(skipping lint — no eslint config yet)\" && exit 0",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@bimo-dk/nexus-core": "*",
    "@bimo-dk/nexus-client": "*",
    "@bimo-dk/nexus-runtime-core": "*"
  },
  "peerDependencies": {
    "vue": "^3.0.0",
    "vue-router": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "vue-router": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "rimraf": "^6.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8",
    "vue": "^3.4.0",
    "vue-router": "^4.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
