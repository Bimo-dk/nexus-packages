{
  "name": "@bimo-dk/nexus-runtime",
  "version": "0.1.0",
  "description": "Angular providers for Bimo-Nexus remotes and hosts — self-registration, runtime config, dynamic federation",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bimo-dk/nexus-packages.git",
    "directory": "packages/runtime"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "lint": "echo \"(skipping lint — no eslint config yet)\" && exit 0",
    "type-check": "tsc --noEmit",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@bimo-dk/nexus-core": "*",
    "@bimo-dk/nexus-client": "*"
  },
  "peerDependencies": {
    "@angular/common": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/router": "^19.0.0",
    "@angular-architects/native-federation": "^19.0.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@angular-architects/native-federation": "^19.0.0",
    "@angular/common": "^19.0.0",
    "@angular/core": "^19.0.0",
    "@angular/router": "^19.0.0",
    "@types/node": "^22.10.0",
    "rimraf": "^6.0.1",
    "rxjs": "^7.8.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
