{
  "name": "nexus-packages",
  "version": "0.0.0",
  "private": true,
  "description": "Bimo-Nexus monorepo — kerne-pakker for micro frontend platformen",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bimo-dk/nexus-packages.git"
  },
  "license": "MIT",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rimraf node_modules",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "turbo run build && changeset publish"
  },
  "overrides": {
    "typescript": "5.6.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "rimraf": "^6.0.1",
    "turbo": "^2.3.3",
    "typescript": "5.6.3"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.9.0"
}
